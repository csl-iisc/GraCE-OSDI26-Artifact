# Example GraCE host tuning profile for Intel Xeon + H100 NVL style machine.
#
# This profile is sourced by:
#   host_tuning/tune_host_intel_h100.sh
#   host_tuning/restore_host_intel_h100.sh
#
# Override any value at invocation time:
#   GPU_CLOCK_MHZ=1410 DISABLE_HT=0 sudo -E host_tuning/tune_host_intel_h100.sh

# GPU clock lock.
GPU_IDS="all"
GPU_CLOCK_MHZ="1410"

# Optional memory clock lock. Leave empty unless you want to lock memory clocks too.
GPU_MEM_CLOCK_MHZ=""

# Intel Xeon Platinum 8462Y+ non-turbo max on example system.
INTEL_TARGET_FREQ_KHZ="2800000"

# Whether the top-level tuning script disables hyperthreading.
# 1: disable HT before running.
# 0: keep HT enabled.
DISABLE_HT="${DISABLE_HT:-1}"

# Explicit HT sibling CPUs for your current topology.
# If empty, disable_hyperthreading.sh auto-detects sibling CPUs.
HT_CPUS="${HT_CPUS:-64-127}"

# Disable deep C6 state.
DISABLE_C6="${DISABLE_C6:-1}"

# Use Docker-aware systemd cpuset isolation.
# Requires:
#   host_tuning/cpuset/setup_docker_bench_cpuset_full.sh
#   host_tuning/cpuset/restore_docker_bench_cpuset.sh
ENABLE_DOCKER_CPUSET="${ENABLE_DOCKER_CPUSET:-1}"

# Docker image used by the cpuset setup script when printing docker run command.
DOCKER_IMAGE="${DOCKER_IMAGE:-grace-osdi26:cuda124-prebuilt}"

# Artifact root inside container.
ARTIFACT_ROOT_IN_CONTAINER="${ARTIFACT_ROOT_IN_CONTAINER:-/workspace/grace-osdi-26-artifact}"