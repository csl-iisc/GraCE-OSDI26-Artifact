# Example profile for AMD EPYC 9554 + RTX A6000 style machine.

GPU_IDS="all"

# Set to a valid clock for the attached GPU.
# Check:
#   nvidia-smi -q -d SUPPORTED_CLOCKS
GPU_CLOCK_MHZ="${GPU_CLOCK_MHZ:-1410}"
GPU_MEM_CLOCK_MHZ=""

AMD_TARGET_FREQ_KHZ="${AMD_TARGET_FREQ_KHZ:-3100000}"

# AMD EPYC machine may have SMT enabled depending on BIOS/kernel config.
DISABLE_HT="${DISABLE_HT:-0}"
HT_CPUS="${HT_CPUS:-}"

DISABLE_C6="${DISABLE_C6:-1}"

ENABLE_DOCKER_CPUSET="${ENABLE_DOCKER_CPUSET:-0}"

DOCKER_IMAGE="${DOCKER_IMAGE:-grace-osdi26:cuda124-prebuilt}"
ARTIFACT_ROOT_IN_CONTAINER="${ARTIFACT_ROOT_IN_CONTAINER:-/workspace/grace-osdi-26-artifact}"